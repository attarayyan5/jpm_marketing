# ===================================
# JP Multiservices - Frontend Config
# Copy this file to .env and update values
# ===================================

# Backend API Base URL (no trailing slash)
# For development: /api (uses Vite proxy)
# For production:

VITE_API_BASE_URL=https://jp-marketing.onrender.com/api

# Uploads Base URL for serving images/files from backend
# For development: /uploads (uses Vite proxy)
# For production: https://your-backend-domain.com/uploads
VITE_UPLOADS_BASE_URL=https://jp-marketing.onrender.com/uploads

# App Metadata
VITE_APP_NAME=JP Multiservices
VITE_APP_VERSION=1.0.0
